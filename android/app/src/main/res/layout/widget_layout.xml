<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ClassWidget"
        android:textColor="#38BDF8"
        android:textSize="14sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <!-- Next Class Countdown (Feature 18) -->
    <LinearLayout
        android:id="@+id/next_class_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/next_class_background"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_menu_recent_history"
            android:layout_gravity="center_vertical"
            android:tint="#38BDF8"/>

        <TextView
            android:id="@+id/next_class_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="#38BDF8"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Empty State (Feature 24) -->
    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="No classes today 🎉"
        android:textColor="#94A3B8"
        android:textSize="16sp"
        android:textStyle="italic"
        android:visibility="gone" />

    <!-- Schedule List -->
    <ListView
        android:id="@+id/widget_list_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@null"
        android:dividerHeight="4dp" />

</LinearLayout>
